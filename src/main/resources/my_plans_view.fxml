<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.solutions.sulmurz.nutricalc.controllers.MyPlansController">
   <effect>
      <ColorAdjust brightness="-0.35" contrast="0.13" hue="0.46" saturation="0.24" />
   </effect>
   <bottom>
      <HBox alignment="CENTER" prefHeight="72.0" prefWidth="800.0" spacing="140.0" BorderPane.alignment="CENTER">
